{
  "$schema": "https://gpu-cli.sh/schema/v1/gpu.json",
  "project_id": "zerostart",
  "gpu_types": [
    { "type": "RTX 4090" },
    { "type": "RTX A6000" }
  ],
  "min_vram": 24,
  "outputs": ["benches/results/"],
  "environment": {
    "system": {
      "apt": [{ "name": "curl" }]
    },
    "shell": {
      "steps": [
        { "run": "curl -LsSf https://astral.sh/uv/install.sh | sh" },
        { "run": "curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y" },
        { "run": "curl -LsSf https://get.nexte.st/latest/linux | tar zxf - -C /root/.cargo/bin" },
        { "run": "chmod +x bin/zs-fast-wheel-linux-x86_64" }
      ]
    }
  },
  "keep_alive_minutes": 10,
  "volume_mode": "global"
}
